---
import Link from '@/components/Link.astro'
import MobileMenu from '@/components/ui/mobile-menu'
import SearchButton from '@/components/react/SearchButton'
import { Button } from '@/components/ui/button'
---

<header class="bg-background sticky top-0 z-10" transition:persist>
  <div class="flex items-center justify-between gap-4 p-4">
    <Link href="/" class="flex shrink-0 items-center gap-2 font-medium" data-astro-reload>
      <img
        src="/static/logo.png"
        alt="Logo"
        class="h-6 w-auto"
        height="24"
        loading="eager"
        fetchpriority="high"
      />
    </Link>
    <div class="flex items-center gap-4">
      <SearchButton client:idle />
      <Link href="/tags">
        <Button variant="outline" size="icon">Tags</Button>
      </Link>
      <MobileMenu client:idle transition:persist />
    </div>
  </div>
</header>
